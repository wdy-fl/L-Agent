# ═══════════════════════════════════════════
# LLM 模型配置
# ═══════════════════════════════════════════
# base_url 需包含版本路径：智谱为 https://open.bigmodel.cn/api/paas/v4
# （OpenAI 兼容端点，客户端只追加 /chat/completions）。
llm:
  base_url: "https://open.bigmodel.cn/api/paas/v4"
  api_key: "这里换成你的智谱api_key"
  model: "glm-5.2"
  temperature: 0.7
  max_tokens: 4096
  # 开启 web 搜索：注册 web_search 客户端工具（调智谱 web-search-pro）。
  web_search: true

# ═══════════════════════════════════════════
# 运行预算限制
# ═══════════════════════════════════════════
budget:
  max_iterations: 25
  max_tokens: 200000

# ═══════════════════════════════════════════
# 工具审批策略
# ═══════════════════════════════════════════
approval:
  auto_approve:
    - think
    - read_file
    - list_directory
    - search_file
    - web_search
  always_confirm:
    - terminal
    - write_file

# ═══════════════════════════════════════════
# 存储配置
# ═══════════════════════════════════════════
storage:
  db_path: "workspace/timeline.db"
