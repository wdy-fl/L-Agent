# ═══════════════════════════════════════════
# LLM 模型配置
# ═══════════════════════════════════════════
llm:
  api_base: "https://api.deepseek.com"
  api_key: "sk-35cc873acd5d4253aafdb64ac3820bef"
  model: "deepseek-v4-pro"
  temperature: 0.7
  max_tokens: 4096

# ═══════════════════════════════════════════
# 运行预算限制
# ═══════════════════════════════════════════
budget:
  max_iterations: 25
  max_tokens: 200000

# ═══════════════════════════════════════════
# 工具审批策略
# ═══════════════════════════════════════════
approval:
  auto_approve:
    - think
    - read_file
    - list_directory
    - search_file
    - web_search
    - web_fetch
  always_confirm:
    - terminal
    - write_file

# ═══════════════════════════════════════════
# 存储配置
# ═══════════════════════════════════════════
storage:
  db_path: "workspace/timeline.db"
